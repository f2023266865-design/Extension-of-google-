{
  "manifest_version": 3,
  "name": "AI Learning Copilot (minimal)",
  "version": "1.0.0",
  "description": "Minimal, no-build extension to test extraction and explain flow.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_title": "AI Learning Copilot",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}
